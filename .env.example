MINUTEFLOW_LLM_API_KEY=

# Optional: multimodal frame analysis
MINUTEFLOW_MM_BASE_URL=
MINUTEFLOW_MM_MODEL=
MINUTEFLOW_MM_API_KEY=

# Optional: speaker diarization
MINUTEFLOW_HF_TOKEN=

# Optional: MCP server listen address for sse / streamable-http
FASTMCP_HOST=
FASTMCP_PORT=
